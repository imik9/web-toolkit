{
  "manifest_version": 3,
  "name": "Web Toolkit",
  "description": "Lightweight browser utilities for magnifying, reading, video speed control, and page inspection.",
  "version": "0.1.0",
  "action": {
    "default_title": "Web Toolkit",
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
